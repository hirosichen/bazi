        </tr>
      </thead>
      <tbody>
        <tr>
          <td>甲</td>
          <td>木</td>
          <td>陽</td>
          <td>大樹、棟梁</td>
          <td>正直剛毅、有領導力、堅持己見</td>
        </tr>
        <tr>
          <td>乙</td>
          <td>木</td>
          <td>陰</td>
          <td>花草、藤蔓</td>
          <td>柔韌靈活、溫和包容、善於適應</td>
        </tr>
