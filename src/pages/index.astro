        </div>
      </div>
    </div>
  </section>

  <!-- Tools Preview -->
  <section class="section" id="tools-preview">
    <div class="container">
      <div class="section-header fade-up">
        <span class="overline">命理工具</span>
        <h2>探索你的命運地圖</h2>
